{
  "name": "dog-parent-simulator",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "prettier --check . && eslint . --max-warnings=0 && npm run build",
    "check:fix": "prettier --write . && eslint . --fix --max-warnings=0 && npm run build",
    "prepare": "lefthook install",
    "preview": "vite preview",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-doctor": "^0.5.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "lefthook@2.1.9": true,
    "fsevents@2.3.3": true
  }
}
