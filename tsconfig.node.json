{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": ".tsbuild/node",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": ".tsbuild/tsconfig.node.tsbuildinfo"
  },
  "include": ["eslint.config.ts", "prettier.config.mts", "vite.config.ts"]
}
